<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <Color x:Key="AsciiBaseColor">#2E0500</Color>
        <Color x:Key="AsciiSurfaceColor">#220300</Color>
        <Color x:Key="AsciiTextColor">#FFB366</Color>
        <Color x:Key="AsciiAccentColor">#FF7A00</Color>
        <Color x:Key="AsciiHighlightColor">#FFE066</Color>
        <Color x:Key="AsciiDialogColor">#9A4A00</Color>
        <Color x:Key="AsciiMutedColor">#C97A33</Color>
        <Color x:Key="AsciiInverseTextColor">#000000</Color>
        <Color x:Key="AsciiProgressPatternStrongColor">#40FFAA55</Color>
        <Color x:Key="AsciiProgressPatternSoftColor">#20FFAA55</Color>
    </Styles.Resources>
</Styles>
