    </Style>

    <Style Selector="Menu > MenuItem">
        <Setter Property="Theme" Value="{StaticResource AsciiTopLevelMenuItemTheme}" />
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Theme" Value="{StaticResource {x:Type ContextMenu}}" />
    </Style>

    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Theme" Value="{StaticResource {x:Type MenuFlyoutPresenter}}" />
    </Style>

    <Style Selector="Expander">
        <Setter Property="Theme" Value="{StaticResource {x:Type Expander}}" />
    </Style>

    <Style Selector="controls|AsciiStatusBar">
        <Setter Property="Theme" Value="{StaticResource {x:Type controls:AsciiStatusBar}}" />
    </Style>

    <Style Selector="controls|AsciiGroupBox">
        <Setter Property="Theme" Value="{StaticResource {x:Type controls:AsciiGroupBox}}" />
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{DynamicResource AsciiPaneBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Theme" Value="{StaticResource {x:Type ListBoxItem}}" />
    </Style>

    <Style Selector="ProgressBar">
        <Setter Property="Theme" Value="{StaticResource {x:Type ProgressBar}}" />
    </Style>

    <Style Selector="Separator">
        <Setter Property="Theme" Value="{StaticResource {x:Type Separator}}" />
    </Style>

    <Style Selector="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
    </Style>

    <Style Selector="TreeViewItem">
        <Setter Property="Theme" Value="{StaticResource {x:Type TreeViewItem}}" />
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{DynamicResource AsciiPaneBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="All" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource AsciiPaneBackgroundBrush}" />
        <Setter Property="ScrollViewer.AllowAutoHide" Value="False" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
        <Setter Property="CanUserResizeColumns" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="False" />
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Theme" Value="{StaticResource AsciiDataGridColumnHeaderTheme}" />
        <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
    </Style>

    <Style Selector="DataGridColumnHeader:pointerover">
        <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
    </Style>

    <Style Selector="DataGridColumnHeader:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
    </Style>

    <Style Selector="DataGridRow:pointerover DataGridCell">
        <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
    </Style>

    <Style Selector="DataGridRow:pointerover DataGridCell TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
    </Style>

    <Style Selector="DataGridRow:selected DataGridCell">
        <Setter Property="Background" Value="{DynamicResource AsciiInputSelectionBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
    </Style>

    <Style Selector="DataGridRow:selected DataGridCell TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
    </Style>

    <Style Selector="DataGrid /template/ ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>

    <Style Selector="DataGrid /template/ DataGridColumnHeadersPresenter#PART_ColumnHeadersPresenter">
        <Setter Property="Margin" Value="0,0,16,0" />
    </Style>

    <Style Selector="DataGrid /template/ DataGridRowsPresenter#PART_RowsPresenter">
        <Setter Property="Margin" Value="0,0,16,16" />
    </Style>

    <Style Selector="DataGrid /template/ Rectangle#PART_BottomRightCorner">
        <Setter Property="Fill" Value="{DynamicResource AsciiPaneBackgroundBrush}" />
    </Style>

    <Style Selector="DataGrid /template/ DataGridColumnHeader#PART_TopRightCornerHeader">
        <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
    </Style>

    <Style Selector="ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
    </Style>

    <Style Selector="ComboBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
    </Style>

    <Style Selector="Menu">
        <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ToolTip">
        <Setter Property="Background" Value="{DynamicResource AsciiPaneSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Slider">
        <Setter Property="Theme" Value="{StaticResource {x:Type Slider}}" />
    </Style>

    <Style Selector="Thumb.ascii-slider-thumb">
        <Setter Property="Background" Value="{DynamicResource AsciiButtonFaceBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" />
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Thumb.ascii-slider-thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AsciiHighlightBrush}" />
    </Style>

    <Style Selector="Thumb.ascii-slider-thumb:pressed">
        <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="LineHeight" Value="{DynamicResource AsciiCellHeight}" />
    </Style>

    <Style Selector="Label">
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Label TextBlock">
        <Setter Property="LineHeight" Value="{DynamicResource AsciiCellHeight}" />
    </Style>

    <Style Selector="Border.ascii-frame">
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</Styles>
