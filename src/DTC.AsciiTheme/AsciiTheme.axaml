<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:Avalonia.Controls.Converters"
        xmlns:controls="using:DTC.AsciiTheme.Controls"
        x:Class="DTC.AsciiTheme.AsciiTheme">

    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

    <Styles.Resources>
        <conv:PlatformKeyGestureConverter x:Key="KeyGestureConverter" />
        <FontFamily x:Key="AsciiFontFamily">avares://DTC.AsciiTheme/Assets/Fonts/VGA#PxPlus IBM VGA8</FontFamily>
        <x:Double x:Key="AsciiCellWidth">8</x:Double>
        <x:Double x:Key="AsciiCellHeight">16</x:Double>

        <!-- Core palette. -->
        <Color x:Key="AsciiBaseColor">#0000AA</Color>
        <Color x:Key="AsciiSurfaceColor">#00008A</Color>
        <Color x:Key="AsciiTextColor">#FFFFFF</Color>
        <Color x:Key="AsciiAccentColor">#55FFFF</Color>
        <Color x:Key="AsciiHighlightColor">#FFFF55</Color>
        <Color x:Key="AsciiDialogColor">#AAAAAA</Color>
        <Color x:Key="AsciiMutedColor">#A0A0A0</Color>
        <Color x:Key="AsciiInverseTextColor">#000000</Color>

        <!-- Shared overlays and texture colors. -->
        <Color x:Key="AsciiShadeSoftColor">#30000000</Color>
        <Color x:Key="AsciiShadeColor">#50000000</Color>
        <Color x:Key="AsciiShadeStrongColor">#80000000</Color>
        <Color x:Key="AsciiLightShadeColor">#20FFFFFF</Color>
        <Color x:Key="AsciiDisabledShadowColor">#40000000</Color>
        <Color x:Key="AsciiProgressPatternStrongColor">#4055FFFF</Color>
        <Color x:Key="AsciiProgressPatternSoftColor">#2055FFFF</Color>

        <!-- Public brush resources used throughout the theme. -->
        <SolidColorBrush x:Key="AsciiBackgroundBrush" Color="{DynamicResource AsciiBaseColor}" />
        <SolidColorBrush x:Key="AsciiForegroundBrush" Color="{DynamicResource AsciiTextColor}" />
        <SolidColorBrush x:Key="AsciiFrameBrush" Color="{DynamicResource AsciiAccentColor}" />
        <SolidColorBrush x:Key="AsciiButtonFaceBrush" Color="{DynamicResource AsciiAccentColor}" />
        <SolidColorBrush x:Key="AsciiButtonForegroundBrush" Color="{DynamicResource AsciiBaseColor}" />
        <SolidColorBrush x:Key="AsciiShadeSoftBrush" Color="{DynamicResource AsciiShadeSoftColor}" />
        <SolidColorBrush x:Key="AsciiShadeBrush" Color="{DynamicResource AsciiShadeColor}" />
        <SolidColorBrush x:Key="AsciiShadeStrongBrush" Color="{DynamicResource AsciiShadeStrongColor}" />
        <SolidColorBrush x:Key="AsciiLightShadeBrush" Color="{DynamicResource AsciiLightShadeColor}" />
        <SolidColorBrush x:Key="AsciiStatusBarBackgroundBrush" Color="{DynamicResource AsciiAccentColor}" />
        <SolidColorBrush x:Key="AsciiPaneBackgroundBrush" Color="{DynamicResource AsciiShadeSoftColor}" />
        <SolidColorBrush x:Key="AsciiPaneSurfaceBrush" Color="{DynamicResource AsciiSurfaceColor}" />
        <SolidColorBrush x:Key="AsciiInputBackgroundBrush" Color="{DynamicResource AsciiShadeColor}" />
        <SolidColorBrush x:Key="AsciiInputHoverBackgroundBrush" Color="{DynamicResource AsciiLightShadeColor}" />
        <SolidColorBrush x:Key="AsciiInputForegroundBrush" Color="{DynamicResource AsciiTextColor}" />
        <SolidColorBrush x:Key="AsciiInputSelectionBrush" Color="{DynamicResource AsciiAccentColor}" />
        <SolidColorBrush x:Key="AsciiInputSelectionForegroundBrush" Color="{DynamicResource AsciiInverseTextColor}" />
        <SolidColorBrush x:Key="AsciiInputWatermarkBrush" Color="{DynamicResource AsciiMutedColor}" />
        <SolidColorBrush x:Key="AsciiHighlightBrush" Color="{DynamicResource AsciiHighlightColor}" />
        <SolidColorBrush x:Key="AsciiHoverBackgroundBrush" Color="{DynamicResource AsciiTextColor}" />
        <SolidColorBrush x:Key="AsciiHoverForegroundBrush" Color="{DynamicResource AsciiBaseColor}" />
        <SolidColorBrush x:Key="AsciiDialogBackgroundBrush" Color="{DynamicResource AsciiDialogColor}" />
        <SolidColorBrush x:Key="AsciiDialogForegroundBrush" Color="{DynamicResource AsciiTextColor}" />
        <SolidColorBrush x:Key="AsciiPressedBackgroundBrush" Color="{DynamicResource AsciiAccentColor}" />
        <SolidColorBrush x:Key="AsciiPressedForegroundBrush" Color="{DynamicResource AsciiInverseTextColor}" />
        <SolidColorBrush x:Key="AsciiDisabledBackgroundBrush" Color="{DynamicResource AsciiShadeSoftColor}" />
        <SolidColorBrush x:Key="AsciiDisabledForegroundBrush" Color="{DynamicResource AsciiMutedColor}" />
        <SolidColorBrush x:Key="AsciiShadowBrush" Color="{DynamicResource AsciiShadeStrongColor}" />
        <SolidColorBrush x:Key="AsciiDisabledShadowBrush" Color="{DynamicResource AsciiDisabledShadowColor}" />
        <SolidColorBrush x:Key="AsciiProgressPatternStrongBrush" Color="{DynamicResource AsciiProgressPatternStrongColor}" />
        <SolidColorBrush x:Key="AsciiProgressPatternSoftBrush" Color="{DynamicResource AsciiProgressPatternSoftColor}" />
        <DrawingBrush x:Key="AsciiProgressTrackBrush"
                      AlignmentX="Left"
                      AlignmentY="Top"
                      DestinationRect="0,0,2,2"
                      Stretch="None"
                      SourceRect="0,0,2,2"
                      TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent"
                                     Geometry="M 0,0 H 2 V 2 H 0 Z" />
                    <GeometryDrawing Brush="{DynamicResource AsciiProgressPatternStrongBrush}"
                                     Geometry="M 0,0 H 1 V 1 H 0 Z" />
                    <GeometryDrawing Brush="{DynamicResource AsciiProgressPatternSoftBrush}"
                                     Geometry="M 1,1 H 2 V 2 H 1 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Thickness x:Key="AsciiControlBorderThickness">1</Thickness>
        <Thickness x:Key="AsciiButtonPadding">8,8</Thickness>
        <Thickness x:Key="AsciiTabPadding">8,8,8,8</Thickness>
        <Thickness x:Key="AsciiTextBoxPadding">8</Thickness>
        <Thickness x:Key="AsciiPanePadding">16</Thickness>
        <Thickness x:Key="AsciiGroupBoxPadding">16,16,16,16</Thickness>
        <x:Double x:Key="AsciiButtonShadowDepth">8</x:Double>
        <x:Double x:Key="AsciiScrollBarThickness">16</x:Double>
        <ControlTheme x:Key="AsciiDataGridColumnHeaderTheme"
                      TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="HeaderBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Name="PART_ColumnHeaderRoot"
                              ColumnDefinitions="*,Auto">
                            <ContentPresenter Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalContentAlignment="Stretch"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.LineHeight="{DynamicResource AsciiCellHeight}" />
                            <TextBlock Name="SortGlyph"
                                       Grid.Column="1"
                                       MinWidth="16"
                                       Margin="0,4,8,4"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text=""
                                       IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover /template/ Grid#PART_ColumnHeaderRoot">
                <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
            </Style>

            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:pressed /template/ Grid#PART_ColumnHeaderRoot">
                <Setter Property="Background" Value="{DynamicResource AsciiHighlightBrush}" />
            </Style>

            <Style Selector="^:pressed">
                <Setter Property="Foreground" Value="{DynamicResource AsciiPressedForegroundBrush}" />
            </Style>

            <Style Selector="^:sortascending /template/ TextBlock#SortGlyph">
                <Setter Property="Text" Value="▲" />
            </Style>

            <Style Selector="^:sortdescending /template/ TextBlock#SortGlyph">
                <Setter Property="Text" Value="▼" />
            </Style>
        </ControlTheme>
        <ControlTheme x:Key="{x:Type Button}"
                      TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AsciiButtonFaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiButtonForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="{DynamicResource AsciiButtonPadding}" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="RightShadow"
                                Width="{DynamicResource AsciiButtonShadowDepth}"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,8"
                                Background="{DynamicResource AsciiShadowBrush}"
                                IsHitTestVisible="False" />

                        <Border Name="BottomShadow"
                                Height="{DynamicResource AsciiButtonShadowDepth}"
                                VerticalAlignment="Bottom"
                                Margin="8,0,8,0"
                                Background="{DynamicResource AsciiShadowBrush}"
                                IsHitTestVisible="False" />

                        <Border Name="CornerShadow"
                                Width="{DynamicResource AsciiButtonShadowDepth}"
                                Height="{DynamicResource AsciiButtonShadowDepth}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="{DynamicResource AsciiShadowBrush}"
                                IsHitTestVisible="False" />

                        <Border Name="Chrome"
                                Margin="0,0,8,8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextBlock.LineHeight="{DynamicResource AsciiCellHeight}"
                                              TextBlock.TextAlignment="Center"
                                              TextBlock.TextWrapping="NoWrap"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True" />
                        </Border>

                        <Border Name="FocusBorder"
                                Margin="2,2,10,10"
                                BorderBrush="{DynamicResource AsciiHighlightBrush}"
                                BorderThickness="1"
                                IsVisible="False"
                                IsHitTestVisible="False" />
                    </Panel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{DynamicResource AsciiPressedBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiPressedForegroundBrush}" />
            </Style>

            <Style Selector="^:pressed /template/ Border#Chrome">
                <Setter Property="Margin" Value="4,4,4,4" />
            </Style>

            <Style Selector="^:pressed /template/ Border#FocusBorder">
                <Setter Property="Margin" Value="6,6,6,6" />
            </Style>

            <Style Selector="^:pressed /template/ Border#RightShadow">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^:pressed /template/ Border#BottomShadow">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^:pressed /template/ Border#CornerShadow">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^:focus /template/ Border#FocusBorder">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="{DynamicResource AsciiDisabledBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>

            <Style Selector="^:disabled /template/ Border#RightShadow">
                <Setter Property="Background" Value="{DynamicResource AsciiDisabledShadowBrush}" />
            </Style>

            <Style Selector="^:disabled /template/ Border#BottomShadow">
                <Setter Property="Background" Value="{DynamicResource AsciiDisabledShadowBrush}" />
            </Style>

            <Style Selector="^:disabled /template/ Border#CornerShadow">
                <Setter Property="Background" Value="{DynamicResource AsciiDisabledShadowBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type ToggleButton}"
                      TargetType="ToggleButton"
                      BasedOn="{StaticResource {x:Type Button}}">
            <Style Selector="^:checked">
                <Setter Property="Background" Value="{DynamicResource AsciiPressedBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiPressedForegroundBrush}" />
            </Style>

            <Style Selector="^:checked /template/ Border#Chrome">
                <Setter Property="Margin" Value="4,4,4,4" />
            </Style>

            <Style Selector="^:checked /template/ Border#FocusBorder">
                <Setter Property="Margin" Value="6,6,6,6" />
            </Style>

            <Style Selector="^:checked /template/ Border#RightShadow">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^:checked /template/ Border#BottomShadow">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^:checked /template/ Border#CornerShadow">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type TabItem}"
                      TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource AsciiControlBorderThickness}" />
            <Setter Property="Padding" Value="{DynamicResource AsciiTabPadding}" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="0,0,-1,-2" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Name="Root"
                           Margin="0">
                        <Border Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Name="PART_HeaderPresenter"
                                              Margin="16,8"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.LineHeight="{DynamicResource AsciiCellHeight}"
                                              TextBlock.TextAlignment="Center"
                                              TextBlock.TextWrapping="NoWrap"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              RecognizesAccessKey="True" />
                        </Border>

                        <Border Name="LastRightEdge"
                                Width="1"
                                HorizontalAlignment="Right"
                                Background="{TemplateBinding BorderBrush}"
                                IsHitTestVisible="False" />

                        <Border Name="FocusBorder"
                                Margin="2,2,2,2"
                                BorderBrush="{DynamicResource AsciiHighlightBrush}"
                                BorderThickness="1"
                                IsVisible="False"
                                IsHitTestVisible="False" />
                    </Panel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource AsciiHighlightBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiPressedForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            </Style>

            <Style Selector="^:selected /template/ Border#Chrome">
                <Setter Property="BorderThickness" Value="1,1,1,0" />
            </Style>

            <Style Selector="^:focus /template/ Border#FocusBorder">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="{DynamicResource AsciiDisabledBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type CheckBox}"
                      TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Name="IndicatorText"
                                       VerticalAlignment="Center"
                                       Text="[ ]" />
                            <ContentPresenter Name="PART_ContentPresenter"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True" />
                        </StackPanel>

                        <Border Name="FocusBorder"
                                Margin="-2"
                                BorderBrush="{DynamicResource AsciiHighlightBrush}"
                                BorderThickness="1"
                                IsVisible="False"
                                IsHitTestVisible="False" />
                    </Panel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:checked /template/ TextBlock#IndicatorText">
                <Setter Property="Text" Value="[x]" />
            </Style>

            <Style Selector="^:indeterminate /template/ TextBlock#IndicatorText">
                <Setter Property="Text" Value="[-]" />
            </Style>

            <Style Selector="^:focus /template/ Border#FocusBorder">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type RadioButton}"
                      TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Name="IndicatorText"
                                       VerticalAlignment="Center"
                                       Text="( )" />
                            <ContentPresenter Name="PART_ContentPresenter"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True" />
                        </StackPanel>

                        <Border Name="FocusBorder"
                                Margin="-2"
                                BorderBrush="{DynamicResource AsciiHighlightBrush}"
                                BorderThickness="1"
                                IsVisible="False"
                                IsHitTestVisible="False" />
                    </Panel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:checked /template/ TextBlock#IndicatorText">
                <Setter Property="Text" Value="(•)" />
            </Style>

            <Style Selector="^:focus /template/ Border#FocusBorder">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type ComboBox}"
                      TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiInputForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputBackgroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="*,16">
                        <Border Name="Chrome"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid ColumnDefinitions="*,16"
                                  ClipToBounds="True">
                                <ContentControl Name="SelectionPresenter"
                                                Grid.Column="0"
                                                Margin="8,4,8,4"
                                                Content="{TemplateBinding SelectionBoxItem}"
                                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

                                <Border Grid.Column="1"
                                        Background="{DynamicResource AsciiPaneBackgroundBrush}" />

                                <TextBlock Name="DropDownGlyph"
                                           Grid.Column="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="▼"
                                           Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>

                        <Popup Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                               MaxHeight="{TemplateBinding MaxDropDownHeight}"
                               MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                               PlacementTarget="Chrome"
                               IsLightDismissEnabled="True"
                               InheritsTransform="True">
                            <Border Name="PopupBorder"
                                    Background="{DynamicResource AsciiPaneSurfaceBrush}"
                                    BorderBrush="{DynamicResource AsciiFrameBrush}"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <ScrollViewer HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                    <ItemsPresenter Name="PART_ItemsPresenter" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:focus /template/ Border#Chrome">
                <Setter Property="BorderBrush" Value="{DynamicResource AsciiHighlightBrush}" />
            </Style>

            <Style Selector="^:dropdownopen /template/ Border#Chrome">
                <Setter Property="BorderBrush" Value="{DynamicResource AsciiHighlightBrush}" />
            </Style>

            <Style Selector="^:dropdownopen /template/ TextBlock#DropDownGlyph">
                <Setter Property="Foreground" Value="{DynamicResource AsciiHighlightBrush}" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Background" Value="{DynamicResource AsciiDisabledBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type ComboBoxItem}"
                      TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource AsciiInputSelectionBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
            </Style>

            <Style Selector="^:selected /template/ ContentPresenter">
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type MenuItem}"
                      TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="PART_LayoutRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <Viewbox Name="PART_IconPresenter"
                                         Grid.Column="0"
                                         Margin="0,0,12,0"
                                         Width="16"
                                         Height="16"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         StretchDirection="DownOnly"
                                         IsVisible="False">
                                    <ContentPresenter Content="{TemplateBinding Icon}" />
                                </Viewbox>

                                <ContentPresenter Name="PART_HeaderPresenter"
                                                  Grid.Column="1"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />

                                <TextBlock Name="PART_InputGestureText"
                                           Grid.Column="2"
                                           Margin="24,0,0,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{Binding InputGesture, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource KeyGestureConverter}}" />

                                <TextBlock Name="PART_ChevronGlyph"
                                           Grid.Column="3"
                                           Margin="12,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="►" />
                            </Grid>
                        </Border>

                        <Popup Name="PART_Popup"
                               WindowManagerAddShadowHint="False"
                               Placement="RightEdgeAlignedTop"
                               HorizontalOffset="-1"
                               IsLightDismissEnabled="False"
                               IsOpen="{TemplateBinding IsSubMenuOpen, Mode=TwoWay}">
                            <Border Name="PART_SubMenuBorder"
                                    Background="{DynamicResource AsciiPaneSurfaceBrush}"
                                    BorderBrush="{DynamicResource AsciiFrameBrush}"
                                    BorderThickness="1"
                                    Padding="0"
                                    CornerRadius="1">
                                <ScrollViewer Theme="{StaticResource FluentMenuScrollViewer}">
                                    <ItemsPresenter Name="PART_ItemsPresenter"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                                    Margin="0"
                                                    Grid.IsSharedSizeScope="True" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Panel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:icon /template/ Viewbox#PART_IconPresenter">
                <Setter Property="IsVisible" Value="True" />
            </Style>

            <Style Selector="^:empty /template/ TextBlock#PART_ChevronGlyph">
                <Setter Property="IsVisible" Value="False" />
            </Style>

            <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
            </Style>

            <Style Selector="^:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:pointerover /template/ TextBlock#PART_InputGestureText">
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource AsciiHighlightBrush}" />
            </Style>

            <Style Selector="^:selected /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
            </Style>

            <Style Selector="^:selected /template/ TextBlock#PART_InputGestureText">
                <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
            </Style>

            <Style Selector="^:pointerover:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
            </Style>

            <Style Selector="^:pointerover:selected /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:pointerover:selected /template/ TextBlock#PART_InputGestureText">
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>

            <Style Selector="^:disabled /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>

            <Style Selector="^:disabled /template/ TextBlock#PART_InputGestureText">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>

            <Style Selector="^:separator">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Separator />
                    </ControlTemplate>
                </Setter>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="AsciiTopLevelMenuItemTheme"
                      TargetType="MenuItem"
                      BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="PART_LayoutRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                <Viewbox Name="PART_IconPresenter"
                                         Grid.Column="0"
                                         Margin="0,0,12,0"
                                         Width="16"
                                         Height="16"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         StretchDirection="DownOnly"
                                         IsVisible="False">
                                    <ContentPresenter Content="{TemplateBinding Icon}" />
                                </Viewbox>

                                <ContentPresenter Name="PART_HeaderPresenter"
                                                  Grid.Column="1"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />

                                <TextBlock Name="PART_InputGestureText"
                                           Grid.Column="2"
                                           Margin="24,0,0,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{Binding InputGesture, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource KeyGestureConverter}}" />

                                <TextBlock Name="PART_ChevronGlyph"
                                           Grid.Column="3"
                                           Margin="12,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="►"
                                           IsVisible="False" />
                            </Grid>
                        </Border>

                        <Popup Name="PART_Popup"
                               WindowManagerAddShadowHint="False"
                               Placement="BottomEdgeAlignedLeft"
                               HorizontalOffset="0"
                               IsLightDismissEnabled="False"
                               IsOpen="{TemplateBinding IsSubMenuOpen, Mode=TwoWay}">
                            <Border Name="PART_SubMenuBorder"
                                    Background="{DynamicResource AsciiPaneSurfaceBrush}"
                                    BorderBrush="{DynamicResource AsciiFrameBrush}"
                                    BorderThickness="1"
                                    Padding="0"
                                    CornerRadius="1">
                                <ScrollViewer Theme="{StaticResource FluentMenuScrollViewer}">
                                    <ItemsPresenter Name="PART_ItemsPresenter"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                                    Margin="0"
                                                    Grid.IsSharedSizeScope="True" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type MenuFlyoutPresenter}"
                      TargetType="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource AsciiPaneSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ScrollViewer HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                      VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                      Theme="{StaticResource FluentMenuScrollViewer}">
                            <ItemsPresenter Name="PART_ItemsPresenter"
                                            ItemsPanel="{TemplateBinding ItemsPanel}"
                                            Margin="0"
                                            KeyboardNavigation.TabNavigation="Continue"
                                            Grid.IsSharedSizeScope="True" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type ContextMenu}"
                      TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource AsciiPaneSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="WindowManagerAddShadowHint" Value="False" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ScrollViewer Theme="{StaticResource FluentMenuScrollViewer}">
                            <ItemsPresenter Name="PART_ItemsPresenter"
                                            ItemsPanel="{TemplateBinding ItemsPanel}"
                                            Margin="0"
                                            KeyboardNavigation.TabNavigation="Continue"
                                            Grid.IsSharedSizeScope="True" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="AsciiExpanderHeaderToggleButtonTheme"
                      TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource AsciiButtonFaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}">
                        <Grid ColumnDefinitions="Auto,*"
                              VerticalAlignment="Center">
                            <TextBlock Name="ExpanderGlyph"
                                       Margin="8,2,8,2"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"
                                       Text="►" />
                            <ContentPresenter Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:checked /template/ TextBlock#ExpanderGlyph">
                <Setter Property="Text" Value="▼" />
            </Style>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiHoverForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type Expander}"
                      TargetType="Expander">
            <Setter Property="Background" Value="{DynamicResource AsciiPaneSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid RowDefinitions="Auto,*">
                            <ToggleButton Name="HeaderToggle"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          Theme="{StaticResource AsciiExpanderHeaderToggleButtonTheme}" />

                            <ContentPresenter Grid.Row="1"
                                              Margin="32,8,16,16"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              IsVisible="{TemplateBinding IsExpanded}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type Slider}"
                      TargetType="Slider">
            <Setter Property="Background" Value="{DynamicResource AsciiShadeSoftBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border Name="TrackBackground"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Height="8"
                                Background="{TemplateBinding Background}" />

                        <Track Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}"
                               Orientation="{TemplateBinding Orientation}"
                               IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                            <Track.DecreaseButton>
                                <RepeatButton Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False" />
                            </Track.DecreaseButton>
                            <Track.Thumb>
                                <Thumb Name="MainThumb"
                                       Width="{DynamicResource AsciiCellWidth}"
                                       Height="{DynamicResource AsciiCellHeight}"
                                       MinWidth="{DynamicResource AsciiCellWidth}"
                                       MinHeight="{DynamicResource AsciiCellHeight}"
                                       HorizontalAlignment="Center"
                                       Background="{DynamicResource AsciiButtonFaceBrush}"
                                       Classes="ascii-slider-thumb" />
                            </Track.Thumb>
                            <Track.IncreaseButton>
                                <RepeatButton Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False" />
                            </Track.IncreaseButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:vertical">
                <Setter Property="MinWidth" Value="24" />
                <Setter Property="MinHeight" Value="160" />
                <Setter Property="Template">
                    <ControlTemplate>
                        <Grid>
                            <Border Name="TrackBackground"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    Width="8"
                                    Background="{TemplateBinding Background}" />

                            <Track Name="PART_Track"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value, Mode=TwoWay}"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                <Track.DecreaseButton>
                                    <RepeatButton Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False" />
                                </Track.DecreaseButton>
                                <Track.Thumb>
                                    <Thumb Name="MainThumb"
                                           Width="{DynamicResource AsciiCellHeight}"
                                           Height="{DynamicResource AsciiCellWidth}"
                                           MinWidth="{DynamicResource AsciiCellHeight}"
                                           MinHeight="{DynamicResource AsciiCellWidth}"
                                           VerticalAlignment="Center"
                                           Background="{DynamicResource AsciiButtonFaceBrush}"
                                           Classes="ascii-slider-thumb" />
                                </Track.Thumb>
                                <Track.IncreaseButton>
                                    <RepeatButton Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False" />
                                </Track.IncreaseButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type controls:AsciiStatusBar}"
                      TargetType="controls:AsciiStatusBar">
            <Setter Property="Background" Value="{DynamicResource AsciiStatusBarBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            Margin="8,-4,8,-4"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Margin="{TemplateBinding Padding}"
                              ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="{TemplateBinding LeftText}"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <Border Grid.Column="1"
                                    Width="1"
                                    Margin="8,0"
                                    Background="{TemplateBinding Foreground}" />

                            <TextBlock Grid.Column="2"
                                       Text="{TemplateBinding RightText}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type controls:AsciiGroupBox}"
                      TargetType="controls:AsciiGroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource AsciiPaneSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="Padding" Value="{DynamicResource AsciiGroupBoxPadding}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid RowDefinitions="Auto,*">
                        <Border Name="Frame"
                                Grid.RowSpan="2"
                                Margin="0,8,0,0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />

                        <Border Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                Background="{TemplateBinding Background}">
                            <Border Padding="8,0"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1,0,1,0">
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  RecognizesAccessKey="True"
                                                  TextBlock.LineHeight="{DynamicResource AsciiCellHeight}" />
                            </Border>
                        </Border>

                        <ContentPresenter Grid.Row="1"
                                          Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type ListBoxItem}"
                      TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="Chrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Border>

                    </Panel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource AsciiInputSelectionBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type ProgressBar}"
                      TargetType="ProgressBar">
            <Setter Property="Background" Value="{DynamicResource AsciiProgressTrackBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiButtonForegroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid ClipToBounds="True">
                            <Border Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource AsciiButtonFaceBrush}" />

                            <Border Name="ProgressTextHost"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="0"
                                    Background="Transparent"
                                    IsVisible="{TemplateBinding ShowProgressText}">
                                <TextBlock Name="ProgressText"
                                           Foreground="{DynamicResource AsciiForegroundBrush}"
                                           Text="{Binding Percentage, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:0}%}" />
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:vertical /template/ Border#PART_Indicator">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
            </Style>

            <Style Selector="^:vertical">
                <Setter Property="MinWidth" Value="8" />
                <Setter Property="MinHeight" Value="64" />
            </Style>

            <Style Selector="^:vertical /template/ Border#ProgressTextHost">
                <Setter Property="RenderTransformOrigin" Value="50%,50%" />
                <Setter Property="RenderTransform">
                    <RotateTransform Angle="270" />
                </Setter>
            </Style>

            <Style Selector="^:indeterminate /template/ Border#PART_Indicator">
                <Setter Property="Width" Value="{Binding TemplateSettings.ContainerWidth, RelativeSource={RelativeSource TemplatedParent}}" />
            </Style>

        </ControlTheme>

        <ControlTheme x:Key="{x:Type Separator}"
                      TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,8" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Foreground}" />
                </ControlTemplate>
            </Setter>

            <Style Selector="^.vertical">
                <Setter Property="Width" Value="1" />
                <Setter Property="Height" Value="NaN" />
                <Setter Property="Margin" Value="8,0" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="AsciiTreeExpanderTheme"
                      TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="16" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:checked">
                <Setter Property="Content" Value="▼" />
            </Style>

            <Style Selector="^:not(:checked)">
                <Setter Property="Content" Value="►" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="{x:Type TreeViewItem}"
                      TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Spacing="0">
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleButton Name="Expander"
                                          Grid.Column="0"
                                          Theme="{StaticResource AsciiTreeExpanderTheme}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />

                            <Border Name="PART_Header"
                                    Grid.Column="1"
                                    Background="{TemplateBinding Background}">
                                <TextBlock Name="PART_HeaderPresenter"
                                           Margin="8,4"
                                           VerticalAlignment="Center"
                                           Text="{TemplateBinding Header}" />
                            </Border>
                        </Grid>

                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        Margin="24,0,0,0"
                                        IsVisible="{TemplateBinding IsExpanded}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:empty /template/ ToggleButton#Expander">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Focusable" Value="False" />
            </Style>

            <Style Selector="^:selected /template/ Border#PART_Header">
                <Setter Property="Background" Value="{DynamicResource AsciiInputSelectionBrush}" />
            </Style>

            <Style Selector="^:selected /template/ TextBlock#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
            </Style>
        </ControlTheme>
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style Selector="Button">
        <Setter Property="Theme" Value="{StaticResource {x:Type Button}}" />
    </Style>

    <Style Selector="ToggleButton">
        <Setter Property="Theme" Value="{StaticResource {x:Type ToggleButton}}" />
    </Style>

    <Style Selector="TabControl">
        <Setter Property="Background" Value="{DynamicResource AsciiBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiForegroundBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="ContentTemplate">
            <DataTemplate>
                <Border Margin="0,-1,0,0"
                        Background="{DynamicResource AsciiPaneBackgroundBrush}"
                        Padding="{DynamicResource AsciiPanePadding}"
                        ClipToBounds="True"
                        BorderBrush="{DynamicResource AsciiFrameBrush}"
                        BorderThickness="1">
                    <ContentPresenter Content="{Binding}" />
                </Border>
            </DataTemplate>
        </Setter>
    </Style>

    <Style Selector="TabControl > TabStrip">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <Style Selector="TabControl > TabStrip > TabItem:last-child">
        <Setter Property="Margin" Value="0,0,0,-2" />
    </Style>

    <Style Selector="TabControl > TabStrip > TabItem:last-child:selected">
        <Setter Property="Margin" Value="0,0,0,-2" />
    </Style>


    <Style Selector="TabItem">
        <Setter Property="Theme" Value="{StaticResource {x:Type TabItem}}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Padding" Value="{DynamicResource AsciiTextBoxPadding}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AsciiHighlightBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AsciiInputSelectionBrush}" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource AsciiInputSelectionForegroundBrush}" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="AllowAutoHide" Value="False" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="*,Auto">
                    <ScrollContentPresenter Name="PART_ContentPresenter"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Background="{TemplateBinding Background}"
                                            Content="{TemplateBinding Content}"
                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                            Padding="{TemplateBinding Padding}"
                                            HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                                            HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                                            VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                                            VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}" />

                    <ScrollBar Name="PART_VerticalScrollBar"
                               Grid.Row="0"
                               Grid.Column="1"
                               Orientation="Vertical" />

                    <ScrollBar Name="PART_HorizontalScrollBar"
                               Grid.Row="1"
                               Grid.Column="0"
                               Orientation="Horizontal" />

                    <Border Name="PART_ScrollBarsSeparator"
                            Grid.Row="1"
                            Grid.Column="1"
                            Background="{DynamicResource AsciiPaneBackgroundBrush}"
                            IsVisible="True" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource AsciiShadeSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="AllowAutoHide" Value="False" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="{DynamicResource AsciiScrollBarThickness}" />
        <Setter Property="MinWidth" Value="{DynamicResource AsciiScrollBarThickness}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid RowDefinitions="Auto,*,Auto"
                      Background="{TemplateBinding Background}">
                    <RepeatButton Name="PART_LineUpButton"
                                  Grid.Row="0"
                                  Width="{TemplateBinding Width}"
                                  Height="{DynamicResource AsciiCellHeight}"
                                  Background="{DynamicResource AsciiPaneBackgroundBrush}"
                                  Classes="ascii-scrollbar-line-button"
                                  Content="▲"
                                  Focusable="False"
                                  Foreground="{TemplateBinding Foreground}" />

                    <Track Grid.Row="1"
                           DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                           IsDirectionReversed="True"
                           Maximum="{TemplateBinding Maximum}"
                           Minimum="{TemplateBinding Minimum}"
                           Orientation="{TemplateBinding Orientation}"
                           Value="{TemplateBinding Value, Mode=TwoWay}"
                           ViewportSize="{TemplateBinding ViewportSize}">
                        <Track.DecreaseButton>
                            <RepeatButton Name="PART_PageUpButton"
                                          Classes="ascii-scrollbar-page-button"
                                          Focusable="False" />
                        </Track.DecreaseButton>
                        <Track.Thumb>
                            <Thumb Name="MainThumb"
                                   Width="{DynamicResource AsciiCellWidth}"
                                   MinHeight="{DynamicResource AsciiCellHeight}"
                                   HorizontalAlignment="Center"
                                   Background="{DynamicResource AsciiButtonFaceBrush}"
                                   Classes="ascii-scrollbar-thumb" />
                        </Track.Thumb>
                        <Track.IncreaseButton>
                            <RepeatButton Name="PART_PageDownButton"
                                          Classes="ascii-scrollbar-page-button"
                                          Focusable="False" />
                        </Track.IncreaseButton>
                    </Track>

                    <RepeatButton Name="PART_LineDownButton"
                                  Grid.Row="2"
                                  Width="{TemplateBinding Width}"
                                  Height="{DynamicResource AsciiCellHeight}"
                                  Background="{DynamicResource AsciiPaneBackgroundBrush}"
                                  Classes="ascii-scrollbar-line-button"
                                  Content="▼"
                                  Focusable="False"
                                  Foreground="{TemplateBinding Foreground}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="{DynamicResource AsciiScrollBarThickness}" />
        <Setter Property="MinHeight" Value="{DynamicResource AsciiScrollBarThickness}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Background="{TemplateBinding Background}">
                    <RepeatButton Name="PART_LineUpButton"
                                  Grid.Column="0"
                                  Width="{DynamicResource AsciiCellHeight}"
                                  Height="{TemplateBinding Height}"
                                  Background="{DynamicResource AsciiPaneBackgroundBrush}"
                                  Classes="ascii-scrollbar-line-button"
                                  Content="◄"
                                  Focusable="False"
                                  Foreground="{TemplateBinding Foreground}" />

                    <Track Grid.Column="1"
                           DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                           Maximum="{TemplateBinding Maximum}"
                           Minimum="{TemplateBinding Minimum}"
                           Orientation="{TemplateBinding Orientation}"
                           Value="{TemplateBinding Value, Mode=TwoWay}"
                           ViewportSize="{TemplateBinding ViewportSize}">
                        <Track.DecreaseButton>
                            <RepeatButton Name="PART_PageUpButton"
                                          Classes="ascii-scrollbar-page-button"
                                          Focusable="False" />
                        </Track.DecreaseButton>
                        <Track.Thumb>
                            <Thumb Name="MainThumb"
                                   Height="{DynamicResource AsciiCellWidth}"
                                   MinWidth="{DynamicResource AsciiCellHeight}"
                                   VerticalAlignment="Center"
                                   Background="{DynamicResource AsciiButtonFaceBrush}"
                                   Classes="ascii-scrollbar-thumb" />
                        </Track.Thumb>
                        <Track.IncreaseButton>
                            <RepeatButton Name="PART_PageDownButton"
                                          Classes="ascii-scrollbar-page-button"
                                          Focusable="False" />
                        </Track.IncreaseButton>
                    </Track>

                    <RepeatButton Name="PART_LineDownButton"
                                  Grid.Column="2"
                                  Width="{DynamicResource AsciiCellHeight}"
                                  Height="{TemplateBinding Height}"
                                  Background="{DynamicResource AsciiPaneBackgroundBrush}"
                                  Classes="ascii-scrollbar-line-button"
                                  Content="►"
                                  Focusable="False"
                                  Foreground="{TemplateBinding Foreground}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Thumb.ascii-scrollbar-thumb">
        <Setter Property="Background" Value="{DynamicResource AsciiButtonFaceBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" />
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Thumb.ascii-scrollbar-thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AsciiHighlightBrush}" />
    </Style>

    <Style Selector="Thumb.ascii-scrollbar-thumb:pressed">
        <Setter Property="Background" Value="{DynamicResource AsciiHoverBackgroundBrush}" />
    </Style>

    <Style Selector="RepeatButton.ascii-scrollbar-page-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" />
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="RepeatButton.ascii-scrollbar-line-button">
        <Setter Property="Background" Value="{DynamicResource AsciiPaneBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiFrameBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AsciiCellHeight}" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="RepeatButton.ascii-scrollbar-line-button:pointerover">
        <Setter Property="Background" Value="{DynamicResource AsciiButtonFaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiButtonForegroundBrush}" />
    </Style>

    <Style Selector="RepeatButton.ascii-scrollbar-line-button:pressed">
        <Setter Property="Background" Value="{DynamicResource AsciiHighlightBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiPressedForegroundBrush}" />
    </Style>

    <Style Selector="TextBox /template/ Border">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBox:pointerover">
        <Setter Property="Background" Value="{DynamicResource AsciiInputHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputHoverBackgroundBrush}" />
    </Style>

    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource AsciiInputHoverBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputHoverBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBox /template/ ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False" />
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputBackgroundBrush}" />
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource AsciiDisabledForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
    </Style>

    <Style Selector="TextBox:disabled /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AsciiInputBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="TextBox /template/ TextBlock#watermark">
        <Setter Property="Foreground" Value="{DynamicResource AsciiInputWatermarkBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AsciiFontFamily}" />
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Theme" Value="{StaticResource {x:Type CheckBox}}" />
    </Style>

    <Style Selector="RadioButton">
        <Setter Property="Theme" Value="{StaticResource {x:Type RadioButton}}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Theme" Value="{StaticResource {x:Type ComboBox}}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Theme" Value="{StaticResource {x:Type ComboBoxItem}}" />
    </Style>

    <Style Selector="MenuItem">
