<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="960"
        d:DesignHeight="640"
        x:Class="DTC.AsciiTheme.Demo.MainWindow"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="520"
        Title="DTC.AsciiTheme Demo">
    <Grid RowDefinitions="Auto,Auto,*"
          Margin="24">
        <StackPanel Spacing="8">
            <TextBlock FontSize="16"
                       Text="DTC.ASCIITHEME :: RETRO CONTROL PREVIEW" />
            <TextBlock Text="A first pass at an Avalonia theme inspired by DOS utilities, BBS tools, and text-mode setup screens." />
            <TextBlock Text="================================================================================" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,16,0,0"
                   Text="[ TABS ]" />

        <TabControl Grid.Row="2"
                    Margin="0,8,0,0">
            <TabItem Header="_Buttons">
                <StackPanel Spacing="16">
                    <TextBlock Text="[ BUTTON ]" />
                    <TextBlock Text="Flat text blocks with DOS-style bottom-right shadowing, inverse-video hover, and a clear keyboard focus ring." />
                    <WrapPanel Orientation="Horizontal"
                               ItemWidth="112"
                               ItemHeight="40">
                        <Button Content="_Normal" />
                        <Button x:Name="FocusedButton"
                                Content="_Focused" />
                        <Button Content="_Disabled"
                                IsEnabled="False" />
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="_Inputs">
                <StackPanel Spacing="16">
                    <TextBlock Text="[ INPUT CONTROLS ]" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="TextBox" />
                        <TextBox Width="320"
                                 Watermark="Enter file name"
                                 Text="CONFIG.SYS" />
                        <TextBox Width="320"
                                 IsEnabled="False"
                                 Text="READONLY.TXT" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="CheckBox" />
                        <CheckBox Content="Item 1"
                                  IsChecked="True" />
                        <CheckBox Content="Item 2"
                                  IsChecked="False" />
                        <CheckBox Content="Item 3"
                                  IsThreeState="True"
                                  IsChecked="{x:Null}"
                                  IsEnabled="False" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="RadioButton" />
                        <RadioButton GroupName="DemoOptions"
                                     Content="Item 1"
                                     IsChecked="True" />
                        <RadioButton GroupName="DemoOptions"
                                     Content="Item 2" />
                        <RadioButton GroupName="DemoOptions"
                                     Content="Item 3"
                                     IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="_Notes">
                <StackPanel Spacing="8">
                    <TextBlock Text="[ NOTES ]" />
                    <TextBlock Text="The demo is now organised like a retro setup utility." />
                    <TextBlock Text="Next controls should follow the same 8x16 grid, palette, and focus language." />
                    <TextBlock Text="Suggested next steps: TextBox, CheckBox, RadioButton." />
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
