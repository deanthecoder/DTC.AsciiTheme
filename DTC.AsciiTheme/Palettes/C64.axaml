<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <FontFamily x:Key="AsciiFontFamily">avares://DTC.AsciiTheme/Assets/Fonts/C64#C64 Pro Mono</FontFamily>
        <Color x:Key="AsciiBaseColor">#4040E0</Color>
        <Color x:Key="AsciiSurfaceColor">#3838C0</Color>
        <Color x:Key="AsciiTextColor">#FFFFFF</Color>
        <Color x:Key="AsciiAccentColor">#FFFFFF</Color>
        <Color x:Key="AsciiHighlightColor">#FFFFFF</Color>
        <Color x:Key="AsciiDialogColor">#3838C0</Color>
        <Color x:Key="AsciiMutedColor">#C0C0FF</Color>
        <Color x:Key="AsciiInverseTextColor">#4040E0</Color>
        <Color x:Key="AsciiProgressPatternStrongColor">#50FFFFFF</Color>
        <Color x:Key="AsciiProgressPatternSoftColor">#20FFFFFF</Color>
    </Styles.Resources>
</Styles>
